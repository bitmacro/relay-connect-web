# relay-connect — copy to `.env` (do not commit secrets)
# relay-api base URL (server only; never expose keys to the browser)
RELAY_API_URL=https://relay-api.bitmacro.io
RELAY_API_KEY=
SIGNER_PROVIDER_USER_ID=

# Optional: relay WebSocket for NIP-46 (required if HTTPS→WSS mapping fails)
NEXT_PUBLIC_RELAY_BRIDGE_WSS=wss://relay.bitmacro.cloud

# Optional: comma/space-separated wss URLs to fetch kind 0 profile after NIP-07 (defaults + NEXT_PUBLIC_RELAY_BRIDGE_WSS first if set)
# NEXT_PUBLIC_NIP07_METADATA_RELAYS=wss://relay.bitmacro.cloud,wss://relay.damus.io

# Optional: relay_configs row UUID when you have several relays
# NEXT_PUBLIC_RELAY_CONFIG_ID=

# Optional: Next.js → relay-api proxy timeout (ms), default 60000
# SIGNER_PROXY_TIMEOUT_MS=60000
